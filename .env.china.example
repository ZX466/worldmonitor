# ========================================
# 中国本土化环境变量配置示例
# China Localization Environment Variables
# ========================================
# 
# 使用方法：
# 1. 复制此文件为 .env.local
# 2. 根据实际情况修改配置值
# 3. 重启开发服务器
#
# Usage:
# 1. Copy this file to .env.local
# 2. Modify values as needed
# 3. Restart the dev server

# ========================================
# 地图服务配置 Map Service Configuration
# ========================================

# 天地图 API Key（推荐）
# 申请地址：https://console.tianditu.gov.cn/api/key
# 免费额度：每日100万次调用
VITE_TIANDITU_KEY=your_tianditu_key_here

# 高德地图 API Key（可选，瓦片服务不需要）
# 申请地址：https://lbs.amap.com/api/javascript-api/guide/abc/prepare
# 免费额度：每日30万次调用
VITE_AMAP_KEY=your_amap_key_here

# 腾讯地图 API Key（可选）
# 申请地址：https://lbs.qq.com/console/mykey.html
# 免费额度：每日10万次调用
VITE_TENCENT_KEY=your_tencent_key_here

# 地图服务选择
# 可选值：tianditu | amap | tencent | geoq
VITE_MAP_PROVIDER=geoq

# ========================================
# 直播源配置 Live Stream Configuration
# ========================================

# 启用中国直播源
# 设置为 true 时，优先使用中国本土直播源
VITE_USE_CHINA_LIVE=true

# 直播源更新URL（可选）
# 用于获取最新的IPTV源列表
VITE_IPTV_UPDATE_URL=https://example.com/iptv-list.m3u

# ========================================
# 新闻源配置 News Source Configuration
# ========================================

# 启用中国新闻源
# 设置为 true 时，优先显示中国新闻源
VITE_USE_CHINA_FEEDS=true

# RSSHub 实例（可选）
# 如果您部署了私有 RSSHub 实例
VITE_RSSHUB_URL=https://rsshub.app

# ========================================
# 社交媒体配置 Social Media Configuration
# ========================================

# 微博 API（需要申请）
# 申请地址：https://open.weibo.com/
VITE_WEIBO_APP_KEY=your_weibo_app_key
VITE_WEIBO_APP_SECRET=your_weibo_app_secret

# 微信公众号（需要配置服务器）
# 由于微信限制，需要后端服务支持
VITE_WECHAT_ENABLED=false

# ========================================
# 数据服务配置 Data Service Configuration
# ========================================

# AIS船舶追踪（中国源）
# 可选：中国船舶自动识别系统
VITE_AIS_CHINA_ENABLED=false

# 航班追踪（中国源）
# 飞常准API：https://www.variflight.com/
VITE_FLIGHT_CN_API_KEY=your_variflight_key

# 天气数据（中国源）
# 中国气象局API：http://www.cma.gov.cn/
VITE_WEATHER_CN_ENABLED=true

# 地震数据（中国源）
# 中国地震台网：https://www.ceic.ac.cn/
VITE_SEISMIC_CN_ENABLED=true

# ========================================
# 基础服务配置 Basic Service Configuration
# ========================================

# 项目变体
# 可选值：full | tech | finance | happy
VITE_VARIANT=full

# 开发服务器端口
VITE_SERVER_PORT=3000

# 是否启用桌面运行时
VITE_DESKTOP_RUNTIME=0

# 是否启用E2E测试模式
VITE_E2E=0

# ========================================
# 性能优化配置 Performance Optimization
# ========================================

# 是否启用Brotli压缩
ENABLE_BROTLI=true

# 数据刷新间隔（毫秒）
VITE_REFRESH_INTERVAL=30000

# 缓存过期时间（秒）
VITE_CACHE_TTL=3600

# ========================================
# 日志和监控 Logging and Monitoring
# ========================================

# Sentry DSN（可选，用于错误监控）
# 国内可能需要代理
VITE_SENTRY_DSN=

# 日志级别
# 可选值：debug | info | warn | error
VITE_LOG_LEVEL=info

# ========================================
# 高级配置 Advanced Configuration
# ========================================

# API代理URL（用于解决跨域）
VITE_API_PROXY_URL=

# WebSocket Relay URL（AIS数据）
VITE_WS_RELAY_URL=

# 是否启用离线模式
VITE_OFFLINE_MODE=false

# ========================================
# 开发者配置 Developer Configuration
# ========================================

# 是否启用调试模式
VITE_DEBUG=false

# 是否启用性能分析
VITE_PROFILING=false

# 自定义地图样式URL
VITE_CUSTOM_MAP_STYLE_URL=

# ========================================
# 使用说明 Usage Guide
# ========================================
#
# 1. 地图服务选择优先级：
#    - 开发测试：使用 GeoQ（无需Key）
#    - 生产部署：使用天地图（推荐）或高德
#
# 2. 申请天地图 Key 的步骤：
#    a. 访问 https://console.tianditu.gov.cn/
#    b. 注册账号并登录
#    c. 创建应用，选择"浏览器端"
#    d. 获取 Key 后填入 VITE_TIANDITU_KEY
#
# 3. 新闻源使用：
#    - 默认已配置中国主流新闻源
#    - 无需额外申请 Key
#    - 可通过 VITE_RSSHUB_URL 配置私有 RSSHub
#
# 4. 直播源更新：
#    - 默认直播源可能随时间失效
#    - 建议定期检查并更新
#    - 可从 https://github.com/fanmingming/live 获取最新源
#
# 5. 合规性注意：
#    - 地图服务需遵守《测绘法》
#    - 新闻转载需获得授权
#    - 直播源需确保来源合法
#
# ========================================
