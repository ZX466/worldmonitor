# ============================================
# World Monitor - 轻量化配置
# 用于减小项目体积，优化部署到轻量服务器
# ============================================

# 站点配置
VITE_VARIANT=full

# 地图配置（使用简化地图样式）
VITE_MAP_STYLE_URL=/map-styles/chinese-simple.json

# 禁用 ML 功能（减小体积）
VITE_DISABLE_ML_WORKER=true

# 禁用高级地图图层
VITE_SIMPLE_MAP_LAYERS=true

# 禁用分析功能（Sentry, Vercel Analytics）
VITE_DISABLE_ANALYTICS=true

# 最小化 API 请求
VITE_MINIMAL_FEEDS=true

# 地图交互模式
VITE_MAP_INTERACTION_MODE=3d

# API 配置
VITE_WS_API_URL=