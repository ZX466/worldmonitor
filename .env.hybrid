# ============================================
# World Monitor — 混合部署环境配置
# 前端：阿里云服务器 | API：Vercel
# ============================================

# ------ 服务器配置 ------
HOST=0.0.0.0
PORT=3000
NODE_ENV=production

# ------ Vercel API 地址 ------
# 部署到 Vercel 后，替换为您的 Vercel 应用 URL
# 格式：https://your-app-name.vercel.app
VITE_WS_API_URL=https://worldmonitor-api.vercel.app

# ------ AI 摘要配置 ------
# Groq API (主要 - 免费层每天14,400次请求)
# 获取地址: https://console.groq.com/
GROQ_API_KEY=

# OpenRouter API (备用 - 免费层每天50次请求)
# 获取地址: https://openrouter.ai/
OPENROUTER_API_KEY=


# ------ 缓存配置 (Upstash Redis) ------
# 用于跨用户缓存和AI调用去重
# 免费创建: https://upstash.com/
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=


# ------ 市场数据 ------
# Finnhub (股票报价 - 免费层可用)
# 注册地址: https://finnhub.io/
FINNHUB_API_KEY=


# ------ 能源数据 ------
# 美国能源信息管理局 (油价、产量、库存)
# 注册地址: https://www.eia.gov/opendata/
EIA_API_KEY=


# ------ 经济数据 ------
# FRED (联邦储备经济数据)
# 注册地址: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=


# ------ 飞机追踪 ------
# Wingbits 飞机数据增强 (所有者、运营商、类型)
# 联系: https://wingbits.com/
WINGBITS_API_KEY=


# ------ 冲突和抗议数据 ------
# ACLED (武装冲突位置和事件数据 - 研究人员免费)
# 注册地址: https://acleddata.com/
ACLED_ACCESS_TOKEN=

# UCDP (乌普萨拉冲突数据项目 - 2025年起需要访问令牌)
# 注册地址: https://ucdp.uu.se/apidocs/
UCDP_ACCESS_TOKEN=


# ------ 互联网中断监控 ------
# Cloudflare Radar API (需要免费的Cloudflare账户和Radar访问权限)
CLOUDFLARE_API_TOKEN=


# ------ 卫星火灾检测 ------
# NASA FIRMS (资源管理系统火灾信息)
# 注册地址: https://firms.modaps.eosdis.nasa.gov/
NASA_FIRMS_API_KEY=


# ------ 网站配置 ------
# 网站变体: "full" (完整版) 或 "tech" (技术版) 或 "finance" (金融版) 或 "happy" (快乐版)
VITE_VARIANT=full

# 地图交互模式:
# - "flat" 保持俯仰/旋转禁用 (2D交互)
# - "3d" 启用俯仰/旋转交互 (默认)
VITE_MAP_INTERACTION_MODE=3d


# ------ 中继服务器配置 ------
# AISStream API 密钥用于实时船舶位置
# 获取地址: https://aisstream.io/
AISSTREAM_API_KEY=

# OpenSky Network OAuth2 凭证 (云IP更高速率限制)
# 注册地址: https://opensky-network.org/
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=


# ------ Telegram OSINT ------
# Telegram MTProto 密钥 (免费): https://my.telegram.org/apps
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# GramJS StringSession 本地生成 (参见: scripts/telegram/session-auth.mjs)
TELEGRAM_SESSION=

# 要摄取的精选列表桶: full | tech | finance
TELEGRAM_CHANNEL_SET=full


# ------ 中继连接 ------
# 服务器端 URL (https://) — Vercel edge函数用于访问中继
WS_RELAY_URL=

# 可选客户端 URL (wss://) — 仅本地/开发回退
VITE_WS_RELAY_URL=

# Vercel和Railway中继之间的共享密钥
# 生产环境中必须在两个平台上设置为相同的值
RELAY_SHARED_SECRET=

# 用于发送中继密钥的标头名称 (必须在两个平台上匹配)
RELAY_AUTH_HEADER=x-relay-key

# 紧急生产覆盖以允许未经身份验证的中继流量
# 生产环境中保持未设置/false
ALLOW_UNAUTHENTICATED_RELAY=false

# 中继 /metrics 端点使用的滚动窗口大小(秒)
RELAY_METRICS_WINDOW_SECONDS=60


# ------ 桌面云回退 ------
# 桌面云回退的有效API密钥列表(逗号分隔)
# 生成命令: openssl rand -hex 24 | sed 's/^/wm_/'
WORLDMONITOR_VALID_KEYS=


# ------ 注册数据库 (Convex) ------
# 用于电子邮件注册存储的Convex部署URL
# 设置地址: https://dashboard.convex.dev/
CONVEX_URL=
