{
  "version": 8,
  "name": "GeoQ Dark",
  "metadata": {
    "owner": "GeoQ",
    "description": "中国本土地图服务 - 深色主题"
  },
  "sources": {
    "geoq-dark": {
      "type": "raster",
      "tiles": [
        "https://map.geoq.cn/ArcGIS/rest/services/ChinaOnlineStreetPurplishBlue/MapServer/tile/{z}/{y}/{x}"
      ],
      "tileSize": 256,
      "attribution": "智图GeoQ"
    }
  },
  "layers": [
    {
      "id": "geoq-dark-layer",
      "type": "raster",
      "source": "geoq-dark",
      "minzoom": 0,
      "maxzoom": 16
    }
  ],
  "glyphs": "https://demotiles.maplibre.org/font/{fontstack}/{range}.pbf",
  "light": {
    "anchor": "viewport",
    "color": "white",
    "intensity": 0.8
  }
}
